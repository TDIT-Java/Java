<?xml version="1.0" encoding="UTF-8"?>
<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components"
        xsi:schemaLocation="
        http://jasperreports.sourceforge.net/jasperreports
        http://jasperreports.sourceforge.net/xsd/jasperreport.xsd
        http://jasperreports.sourceforge.net/jasperreports/components
        http://jasperreports.sourceforge.net/xsd/components.xsd"
        name="ElectricityBill"
        pageWidth="595"
        pageHeight="842"
        columnWidth="555"
        leftMargin="20"
        rightMargin="20"
        topMargin="20"
        bottomMargin="20">

    <!-- ========================= -->
    <!-- SUBDATASETS FIRST -->
    <!-- ========================= -->

    <subDataset name="PendingDataset">
        <field name="month"  class="java.lang.String"/>
        <field name="units"  class="java.lang.Integer"/>
        <field name="amount" class="java.lang.Double"/>
    </subDataset>

    <subDataset name="PastDataset">
        <field name="month"    class="java.lang.String"/>
        <field name="units"    class="java.lang.Integer"/>
        <field name="billPaid" class="java.lang.Double"/>
    </subDataset>

    <!-- ========================= -->
    <!-- PARAMETERS -->
    <!-- ========================= -->

    <parameter name="PendingBillsDS"
               class="net.sf.jasperreports.engine.data.JRBeanCollectionDataSource"
               isForPrompting="false"/>

    <parameter name="PastBillsDS"
               class="net.sf.jasperreports.engine.data.JRBeanCollectionDataSource"
               isForPrompting="false"/>

    <!-- ========================= -->
    <!-- MAIN FIELDS -->
    <!-- ========================= -->

    <field name="customerName"      class="java.lang.String"/>
    <field name="customerId"        class="java.lang.String"/>
    <field name="billingAddress"    class="java.lang.String"/>
    <field name="emailId"           class="java.lang.String"/>
    <field name="phoneNumber"       class="java.lang.String"/>
    <field name="billNumber"        class="java.lang.String"/>
    <field name="billDate"          class="java.lang.String"/>
    <field name="dueDate"           class="java.lang.String"/>
    <field name="meterReadingDate"  class="java.lang.String"/>
    <field name="billGeneratedDate" class="java.lang.String"/>
    <field name="currentReading"    class="java.lang.Integer"/>
    <field name="previousReading"   class="java.lang.Integer"/>
    <field name="ratePerUnit"       class="java.lang.Double"/>
    <field name="unitsConsumed"     class="java.lang.Integer"/>
    <field name="totalAmountPay"    class="java.lang.Double"/>
    <field name="afterDueAmount"    class="java.lang.Double"/>
    <field name="qrData"            class="java.lang.String"/>

    <!-- ========================= -->
    <!-- TITLE -->
    <!-- ========================= -->

    <title>
        <band height="50" splitType="Stretch">

            <staticText>
                <reportElement x="0" y="0" width="300" height="30"/>
                <textElement>
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[ELECTRICITY BOARD]]></text>
            </staticText>

            <staticText>
                <reportElement x="355" y="0" width="200" height="30"/>
                <textElement textAlignment="Right">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[ELECTRICITY BILL]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="42" width="555" height="1"/>
            </line>

        </band>
    </title>

    <!-- ========================= -->
    <!-- DETAIL -->
    <!-- ========================= -->

    <detail>
        <band height="120" splitType="Stretch">

            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="0" width="270" height="20"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Customer: " + $F{customerName}]]>
                </textFieldExpression>
            </textField>

            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="20" width="270" height="20"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Consumer No: " + $F{customerId}]]>
                </textFieldExpression>
            </textField>

            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="40" width="270" height="20"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Email: " + $F{emailId}]]>
                </textFieldExpression>
            </textField>

            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="60" width="270" height="20"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Phone: " + $F{phoneNumber}]]>
                </textFieldExpression>
            </textField>

            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="80" width="270" height="20"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Address: " + $F{billingAddress}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="285" y="0" width="270" height="20"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Bill No: " + $F{billNumber}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="285" y="20" width="270" height="20"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Bill Date: " + $F{billDate}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="285" y="40" width="270" height="20"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Due Date: " + $F{dueDate}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="285" y="60" width="270" height="20"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Meter Date: " + $F{meterReadingDate}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="285" y="80" width="270" height="20"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Generated: " + $F{billGeneratedDate}]]>
                </textFieldExpression>
            </textField>

        </band>
    </detail>

    <!-- ========================= -->
    <!-- SUMMARY -->
    <!-- ========================= -->

    <summary>
        <band height="570" splitType="Stretch">

            <!-- Section Title -->
            <staticText>
                <reportElement x="0" y="0" width="555" height="20"/>
                <textElement>
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Billing Summary]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="22" width="555" height="1"/>
            </line>

            <!-- Reading Details -->
            <textField>
                <reportElement x="0" y="30" width="185" height="20"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Prev Reading: " + $F{previousReading}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="190" y="30" width="185" height="20"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Curr Reading: " + $F{currentReading}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="380" y="30" width="175" height="20"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Units: " + $F{unitsConsumed}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="55" width="270" height="20"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Rate/Unit: Rs. " + String.format("%.4f", $F{ratePerUnit})]]>
                </textFieldExpression>
            </textField>

            <!-- ======= PENDING BILLS TABLE ======= -->

            <staticText>
                <reportElement x="0" y="85" width="555" height="20"/>
                <textElement>
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Pending Bills]]></text>
            </staticText>

            <!-- ✅ Fix: componentElement with correct jr:table structure -->
            <componentElement>
                <reportElement x="0" y="108" width="555" height="120"/>
                <jr:table>
                    <datasetRun subDataset="PendingDataset">
                        <dataSourceExpression>
                            <![CDATA[$P{PendingBillsDS}]]>
                        </dataSourceExpression>
                    </datasetRun>

                    <jr:column width="185">
                        <jr:columnHeader height="20" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0"
                                               width="185" height="20"
                                               backcolor="#CCCCCC"
                                               mode="Opaque"/>
                                <textElement>
                                    <font isBold="true" size="10"/>
                                </textElement>
                                <text><![CDATA[Month]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="20" rowSpan="1">
                            <textField>
                                <reportElement x="0" y="0"
                                               width="185" height="20"/>
                                <textElement><font size="10"/></textElement>
                                <textFieldExpression>
                                    <![CDATA[$F{month}]]>
                                </textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="185">
                        <jr:columnHeader height="20" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0"
                                               width="185" height="20"
                                               backcolor="#CCCCCC"
                                               mode="Opaque"/>
                                <textElement>
                                    <font isBold="true" size="10"/>
                                </textElement>
                                <text><![CDATA[Units]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="20" rowSpan="1">
                            <textField>
                                <reportElement x="0" y="0"
                                               width="185" height="20"/>
                                <textElement><font size="10"/></textElement>
                                <textFieldExpression>
                                    <![CDATA[$F{units}]]>
                                </textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="185">
                        <jr:columnHeader height="20" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0"
                                               width="185" height="20"
                                               backcolor="#CCCCCC"
                                               mode="Opaque"/>
                                <textElement>
                                    <font isBold="true" size="10"/>
                                </textElement>
                                <text><![CDATA[Amount (Rs.)]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="20" rowSpan="1">
                            <textField>
                                <reportElement x="0" y="0"
                                               width="185" height="20"/>
                                <textElement><font size="10"/></textElement>
                                <textFieldExpression>
                                    <![CDATA[String.format("%.2f", $F{amount})]]>
                                </textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                </jr:table>
            </componentElement>

            <!-- ======= TOTAL + QR ======= -->

            <textField>
                <reportElement x="0" y="240" width="300" height="30"/>
                <textElement>
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Total: Rs. " + String.format("%.2f", $F{totalAmountPay})]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="275" width="300" height="20"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["Due Date: " + $F{dueDate}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="298" width="300" height="20"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression>
                    <![CDATA["After Due: Rs. " + String.format("%.2f", $F{afterDueAmount})]]>
                </textFieldExpression>
            </textField>

            <!-- ✅ QR Code using ZXing BufferedImage -->
            <image scaleImage="RetainShape">
                <reportElement x="390" y="235" width="120" height="120"/>
                <imageExpression>
                    <![CDATA[
                        com.google.zxing.client.j2se.MatrixToImageWriter.toBufferedImage(
                            new com.google.zxing.qrcode.QRCodeWriter().encode(
                                $F{qrData},
                                com.google.zxing.BarcodeFormat.QR_CODE,
                                150,
                                150
                            )
                        )
                    ]]>
                </imageExpression>
            </image>

            <!-- ======= PAST BILLS TABLE ======= -->

            <staticText>
                <reportElement x="0" y="330" width="555" height="20"/>
                <textElement>
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Payment History (Last 6 Months)]]></text>
            </staticText>

            <componentElement>
                <reportElement x="0" y="353" width="555" height="120"/>
                <jr:table>
                    <datasetRun subDataset="PastDataset">
                        <dataSourceExpression>
                            <![CDATA[$P{PastBillsDS}]]>
                        </dataSourceExpression>
                    </datasetRun>

                    <jr:column width="185">
                        <jr:columnHeader height="20" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0"
                                               width="185" height="20"
                                               backcolor="#CCCCCC"
                                               mode="Opaque"/>
                                <textElement>
                                    <font isBold="true" size="10"/>
                                </textElement>
                                <text><![CDATA[Month]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="20" rowSpan="1">
                            <textField>
                                <reportElement x="0" y="0"
                                               width="185" height="20"/>
                                <textElement><font size="10"/></textElement>
                                <textFieldExpression>
                                    <![CDATA[$F{month}]]>
                                </textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="185">
                        <jr:columnHeader height="20" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0"
                                               width="185" height="20"
                                               backcolor="#CCCCCC"
                                               mode="Opaque"/>
                                <textElement>
                                    <font isBold="true" size="10"/>
                                </textElement>
                                <text><![CDATA[Units]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="20" rowSpan="1">
                            <textField>
                                <reportElement x="0" y="0"
                                               width="185" height="20"/>
                                <textElement><font size="10"/></textElement>
                                <textFieldExpression>
                                    <![CDATA[$F{units}]]>
                                </textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="185">
                        <jr:columnHeader height="20" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0"
                                               width="185" height="20"
                                               backcolor="#CCCCCC"
                                               mode="Opaque"/>
                                <textElement>
                                    <font isBold="true" size="10"/>
                                </textElement>
                                <text><![CDATA[Amount Paid (Rs.)]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="20" rowSpan="1">
                            <textField>
                                <reportElement x="0" y="0"
                                               width="185" height="20"/>
                                <textElement><font size="10"/></textElement>
                                <textFieldExpression>
                                    <![CDATA[String.format("%.2f", $F{billPaid})]]>
                                </textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                </jr:table>
            </componentElement>

            <!-- Footer -->
            <staticText>
                <reportElement x="0" y="500" width="555" height="20"/>
                <textElement textAlignment="Center">
                    <font size="8" isItalic="true"/>
                </textElement>
                <text>
                    <![CDATA[This is a computer-generated bill. No signature required.]]>
                </text>
            </staticText>

        </band>
    </summary>

</jasperReport>