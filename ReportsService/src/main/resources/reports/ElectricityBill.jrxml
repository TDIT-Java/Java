<?xml version="1.0" encoding="UTF-8"?>
<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
        name="ElectricityBill"
        pageWidth="595" pageHeight="842"
        columnWidth="555"
        leftMargin="20" rightMargin="20"
        topMargin="20" bottomMargin="20">

    <!-- ================= STYLES ================= -->
    <style name="SectionHeader"
           forecolor="#FFFFFF"
           backcolor="#0F0FA3"
           isBold="true"
           fontSize="10"
           mode="Opaque"/>

    <style name="TableHeader"
           forecolor="#FFFFFF"
           backcolor="#333399"
           isBold="true"
           fontSize="9"
           mode="Opaque"/>

    <style name="TableCell"
           forecolor="#333333"
           fontSize="9"
           mode="Opaque"/>

    <!-- ================= PARAMETERS ================= -->
    <parameter name="customerName" class="java.lang.String"/>
    <parameter name="customerId" class="java.lang.String"/>
    <parameter name="billingAddress" class="java.lang.String"/>
    <parameter name="emailId" class="java.lang.String"/>
    <parameter name="phoneNumber" class="java.lang.String"/>

    <parameter name="billNumber" class="java.lang.String"/>
    <parameter name="billDate" class="java.lang.String"/>
    <parameter name="dueDate" class="java.lang.String"/>
    <parameter name="meterReadingDate" class="java.lang.String"/>
    <parameter name="billGeneratedDate" class="java.lang.String"/>
    <parameter name="billType" class="java.lang.String"/>

    <parameter name="currentReading" class="java.lang.Integer"/>
    <parameter name="previousReading" class="java.lang.Integer"/>
    <parameter name="unitsConsumed" class="java.lang.Integer"/>
    <parameter name="ratePerUnit" class="java.lang.Double"/>

    <parameter name="totalAmountPay" class="java.lang.Double"/>
    <parameter name="afterDueAmount" class="java.lang.Double"/>

    <parameter name="pendingMonths" class="java.util.List"/>
    <parameter name="pendingUnits" class="java.util.List"/>
    <parameter name="pendingAmounts" class="java.util.List"/>

    <parameter name="pastMonths" class="java.util.List"/>
    <parameter name="pastUnits" class="java.util.List"/>
    <parameter name="pastAmounts" class="java.util.List"/>

    <parameter name="billPaidDateTime" class="java.util.List"/>

    <parameter name="qrImage" class="java.io.InputStream"/>

    <!-- ================= TITLE BAND ================= -->
    <title>
        <band height="75" splitType="Stretch">

            <image scaleImage="RetainShape" hAlign="Left" vAlign="Middle" onErrorType="Blank">
                <reportElement x="0" y="5" width="65" height="60"/>
                <imageExpression><![CDATA["logo.png"]]></imageExpression>
            </image>

            <staticText>
                <reportElement x="72" y="10" width="250" height="22" forecolor="#0F0FA3"/>
                <textElement verticalAlignment="Middle">
                    <font size="16" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[ELECTRICITY BOARD]]></text>
            </staticText>

            <staticText>
                <reportElement x="72" y="33" width="250" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isItalic="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Powering Your World, Every Day]]></text>
            </staticText>

            <textField isBlankWhenNull="true">
                <reportElement x="300" y="3" width="200" height="24" forecolor="#FF0000">
                    <printWhenExpression>
                        <![CDATA["DUPLICATE".equals($P{billType})]]>
                    </printWhenExpression>
                </reportElement>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="11" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["DUPLICATE"]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="15" width="200" height="24" forecolor="#0F0FA3"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="18" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[ELECTRICITY BILL]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="72" width="555" height="1" forecolor="#0F0FA3"/>
                <graphicElement>
                    <pen lineWidth="1.5"/>
                </graphicElement>
            </line>

        </band>
    </title>

    <!-- ================= DETAIL BAND ================= -->
    <!--
        LAYOUT MAP:
        y=0   - 20  : Section 1 Header
        y=20  - 115 : Consumer Details Box       (height=95)
        y=115 - 122 : gap (7px)
        y=122 - 142 : Section 2 Header           (height=20)
        y=142 - 202 : Billing Summary Box        (height=60)
        y=202 - 210 : gap (8px)
        y=210 - 230 : Section 3 Header           (height=20)
        y=230 - 250 : Pending Table Header       (height=20)
        y=250 - 268 : Pending Row 1              (height=18)
        y=268 - 286 : Pending Row 2              (height=18)
        y=286 - 304 : Pending Row 3              (height=18)
        y=304 - 312 : gap (8px)
        y=312 - 392 : Payment Box + QR           (height=80)
        y=392 - 400 : gap (8px)
        y=400 - 420 : Section 5 Header           (height=20)
        y=420 - 440 : Past Table Header          (height=20)
        y=440 - 458 : Past Row 1                 (height=18)
        y=458 - 476 : Past Row 2                 (height=18)
        y=476 - 494 : Past Row 3                 (height=18)
        y=494 - 502 : gap (8px)
        y=502 - 544 : Notice Box                 (height=42)
        y=544 - 552 : gap (8px)
        y=552 - 553 : Footer divider line        (height=1)
        y=554 - 654 : Advertisement image        (height=100)
        y=654 - 670 : Footer text 1              (height=16)
        y=670 - 682 : Footer text 2              (height=12)
        Band height  = 685
    -->
    <detail>
        <band height="718" splitType="Stretch">

            <!-- ===== SECTION 1: Consumer Details ===== -->
            <rectangle radius="3">
                <reportElement x="0" y="0" width="555" height="20"
                               backcolor="#0F0FA3" forecolor="#0F0FA3" mode="Opaque"/>
            </rectangle>
            <staticText>
                <reportElement x="5" y="2" width="300" height="16" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  Consumer Details]]></text>
            </staticText>

            <!-- Consumer Box -->
            <rectangle radius="2">
                <reportElement x="0" y="20" width="555" height="95"
                               forecolor="#CCCCCC" backcolor="#FAFAFA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.75" lineColor="#CCCCCC"/>
                </graphicElement>
            </rectangle>

            <!-- LEFT COLUMN -->
            <textField isBlankWhenNull="true">
                <reportElement x="8" y="26" width="270" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Name:  " + $P{customerName}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="8" y="43" width="270" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Consumer ID:  " + $P{customerId}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="8" y="60" width="270" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Address:  " + $P{billingAddress}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="8" y="77" width="270" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Email:  " + $P{emailId}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="8" y="94" width="270" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Phone:  " + $P{phoneNumber}]]></textFieldExpression>
            </textField>

            <!-- Vertical Divider -->
            <line>
                <reportElement x="285" y="22" width="1" height="91" forecolor="#CCCCCC"/>
                <graphicElement>
                    <pen lineWidth="0.75" lineStyle="Dashed"/>
                </graphicElement>
            </line>

            <!-- RIGHT COLUMN -->
            <textField isBlankWhenNull="true">
                <reportElement x="293" y="26" width="257" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Bill No:  " + $P{billNumber}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="293" y="43" width="257" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Bill Date:  " + $P{billDate}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="293" y="60" width="257" height="16" forecolor="#FF0000"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Due Date:  " + $P{dueDate}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="293" y="77" width="257" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Meter Reading Date:  " + $P{meterReadingDate}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="293" y="94" width="257" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Bill Generated:  " + $P{billGeneratedDate}]]></textFieldExpression>
            </textField>

            <!-- ===== SECTION 2: Billing Summary ===== -->
            <rectangle radius="3">
                <reportElement x="0" y="122" width="555" height="20"
                               backcolor="#0F0FA3" forecolor="#0F0FA3" mode="Opaque"/>
            </rectangle>
            <staticText>
                <reportElement x="5" y="124" width="300" height="16" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  Billing Summary]]></text>
            </staticText>

            <!-- Summary Box -->
            <rectangle radius="2">
                <reportElement x="0" y="142" width="555" height="60"
                               forecolor="#CCCCCC" backcolor="#FAFAFA" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.75" lineColor="#CCCCCC"/>
                </graphicElement>
            </rectangle>

            <!-- Left: Reading Info -->
            <textField isBlankWhenNull="true">
                <reportElement x="8" y="148" width="270" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Current Reading:  " + $P{currentReading} + "  units"]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="8" y="165" width="270" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Previous Reading:  " + $P{previousReading} + "  units"]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="8" y="182" width="270" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Units Consumed:  " + $P{unitsConsumed} + "  units"]]></textFieldExpression>
            </textField>

            <!-- Vertical Divider -->
            <line>
                <reportElement x="285" y="144" width="1" height="56" forecolor="#CCCCCC"/>
                <graphicElement>
                    <pen lineWidth="0.75" lineStyle="Dashed"/>
                </graphicElement>
            </line>

            <!-- Right: Rate -->
            <textField isBlankWhenNull="true">
                <reportElement x="293" y="165" width="257" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Rate Per Unit:  \u20B9 " + $P{ratePerUnit}]]></textFieldExpression>
            </textField>

            <!-- ===== SECTION 3: Pending Bills ===== -->
            <rectangle radius="3">
                <reportElement x="0" y="210" width="555" height="20"
                               backcolor="#C0392B" forecolor="#C0392B" mode="Opaque"/>
            </rectangle>
            <staticText>
                <reportElement x="5" y="212" width="300" height="16" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[ Past 3 - Months Pending Bills]]></text>
            </staticText>

            <!-- Pending Table Header -->
            <!--
                Column Layout (total = 555px):
                Month      : x=0,   width=120  (0   to 120)
                Units      : x=120, width=120  (120 to 240)
                Amount Due : x=240, width=315  (240 to 555)
            -->
            <rectangle>
                <reportElement x="0" y="230" width="555" height="20"
                               backcolor="#F2D7D5" forecolor="#F2D7D5" mode="Opaque"/>
            </rectangle>

            <staticText>
                <reportElement x="5" y="232" width="115" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Month]]></text>
            </staticText>
            <staticText>
                <reportElement x="125" y="232" width="115" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Units]]></text>
            </staticText>
            <staticText>
                <reportElement x="245" y="232" width="305" height="16" forecolor="#333333"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Amount Due]]></text>
            </staticText>

            <!-- Pending Row 1 (y=250, height=18, ends=268) -->
            <rectangle>
                <reportElement x="0" y="250" width="555" height="18"
                               backcolor="#FFFFFF" forecolor="#DDDDDD" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <textField isBlankWhenNull="true">
                <reportElement x="5" y="252" width="115" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{pendingMonths}.size()>0 ? $P{pendingMonths}.get(0) : "-"]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="125" y="252" width="115" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{pendingUnits}.size()>0 ? $P{pendingUnits}.get(0) : "-"]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="245" y="252" width="305" height="14" forecolor="#C0392B"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{pendingAmounts}.size()>0 ? "\u20B9 " + $P{pendingAmounts}.get(0) : "-"]]></textFieldExpression>
            </textField>

            <!-- Pending Row 2 (y=268, height=18, ends=286) -->
            <rectangle>
                <reportElement x="0" y="268" width="555" height="18"
                               backcolor="#FEF9F9" forecolor="#DDDDDD" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <textField isBlankWhenNull="true">
                <reportElement x="5" y="270" width="115" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{pendingMonths}.size()>1 ? $P{pendingMonths}.get(1) : "-"]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="125" y="270" width="115" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{pendingUnits}.size()>1 ? $P{pendingUnits}.get(1) : "-"]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="245" y="270" width="305" height="14" forecolor="#C0392B"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{pendingAmounts}.size()>1 ? "\u20B9 " + $P{pendingAmounts}.get(1) : "-"]]></textFieldExpression>
            </textField>

            <!-- Pending Row 3 (y=286, height=18, ends=304) -->
            <rectangle>
                <reportElement x="0" y="286" width="555" height="18"
                               backcolor="#FFFFFF" forecolor="#DDDDDD" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <textField isBlankWhenNull="true">
                <reportElement x="5" y="288" width="115" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{pendingMonths}.size()>2 ? $P{pendingMonths}.get(2) : "-"]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="125" y="288" width="115" height="14" forecolor="#555555"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{pendingUnits}.size()>2 ? $P{pendingUnits}.get(2) : "-"]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="245" y="288" width="305" height="14" forecolor="#C0392B"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{pendingAmounts}.size()>2 ? "\u20B9 " + $P{pendingAmounts}.get(2) : "-"]]></textFieldExpression>
            </textField>

            <!-- ===== SECTION 4: Payment Details + QR Code ===== -->
            <!-- Payment box: y=312, height=80, ends=392 -->
            <rectangle radius="4">
                <reportElement x="0" y="312" width="415" height="80"
                               backcolor="#EBF5FB" forecolor="#1A5276" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="1.5" lineColor="#1A5276"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="8" y="316" width="400" height="16" forecolor="#1A5276"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Payment Details]]></text>
            </staticText>

            <line>
                <reportElement x="8" y="333" width="399" height="1" forecolor="#1A5276"/>
            </line>

            <textField isBlankWhenNull="true">
                <reportElement x="8" y="335" width="400" height="16" forecolor="#1A5276"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Total Amount to Pay:   \u20B9 " + $P{totalAmountPay}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="8" y="353" width="400" height="16" forecolor="#555555"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression><![CDATA["Due Date:   " + $P{dueDate}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="8" y="370" width="400" height="18" forecolor="#C0392B"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["After Due Date:   \u20B9 " + $P{afterDueAmount} + "  (incl. \u20B9 10 late charges)"]]></textFieldExpression>
            </textField>

            <!-- QR Code Box: x=420, width=135, total=555 ✓ -->
            <rectangle radius="4">
                <reportElement x="420" y="312" width="135" height="80"
                               backcolor="#F8F9FA" forecolor="#CCCCCC" mode="Opaque"/>
                <graphicElement>
                    <pen lineWidth="0.75"/>
                </graphicElement>
            </rectangle>

            <!-- QR image: x=432, width=72, ends=504 ✓ centered in box -->
            <image scaleImage="RetainShape" hAlign="Center" vAlign="Middle">
                <reportElement x="432" y="315" width="72" height="55"/>
                <imageExpression><![CDATA[$P{qrImage}]]></imageExpression>
            </image>

            <staticText>
                <reportElement x="400" y="371" width="135" height="16" forecolor="#0F0FA3"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Scan to Pay]]></text>
            </staticText>

            <!-- ===== SECTION 5: Past 3 Months ===== -->
            <!-- Section header: y=400, height=20, ends=420 -->
            <rectangle radius="3">
                <reportElement x="0" y="400" width="555" height="20"
                               backcolor="#1E8449" forecolor="#1E8449" mode="Opaque"/>
            </rectangle>
            <staticText>
                <reportElement x="5" y="402" width="500" height="16" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="10" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[  Past 3 Months - Units Consumed & Bill Paid]]></text>
            </staticText>

            <!-- Past Table Header -->
            <!--
                Column Layout (total = 555px):
                Bill Month       : x=0,   width=130  (0   to 130)
                Units Consumed   : x=130, width=110  (130 to 240)
                Bill Paid Amount : x=240, width=110  (240 to 350)
                Bill Paid D&T    : x=350, width=205  (350 to 555)
            -->
            <rectangle>
                <reportElement x="0" y="420" width="555" height="20"
                               backcolor="#D5F5E3" forecolor="#D5F5E3" mode="Opaque"/>
            </rectangle>

            <staticText>
                <reportElement x="5" y="422" width="125" height="16" forecolor="#1E8449"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Bill Month]]></text>
            </staticText>
            <staticText>
                <reportElement x="135" y="422" width="105" height="16" forecolor="#1E8449"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Units Consumed]]></text>
            </staticText>
            <staticText>
