                <textElement verticalAlignment="Middle">
                    <font size="9" fontName="SansSerif"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{pastAmounts}.size()>2 ? "\u20B9 " + $P{pastAmounts}.get(2) : "-"]]></textFieldExpression>
            </textField>

            <!-- ===== IMPORTANT NOTICE BOX ===== -->
            <rectangle radius="4">
                <reportElement x="0" y="490" width="555" height="45"
