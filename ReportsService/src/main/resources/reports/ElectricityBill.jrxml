                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="8" y="494" width="540" height="14" forecolor="#7D6608"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[Important Notice:]]></text>
            </staticText>

            <staticText>
                <reportElement x="8" y="509" width="540" height="22" forecolor="#7D6608"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" fontName="SansSerif"/>
                </textElement>
                <text>
                    <![CDATA[Please pay your bill before the due date to avoid late charges. For queries call 1800-123-4567 (Toll Free).]]></text>
            </staticText>

            <!-- ===== FOOTER ===== -->
            <line>
                <reportElement x="0" y="543" width="555" height="1" forecolor="#0F0FA3"/>
